FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Role assignment by Firebase UID (comma-separated)
# Get UIDs from Firebase Console -> Authentication -> Users after first sign-in
# Use the SAME UID lists in all four vars below.
#
# Server-only (API routes on Vercel/Node):
#   ADMIN_UIDS, STAFF_UIDS
# Client + server (login pages and auth guards in the browser need NEXT_PUBLIC_*):
#   NEXT_PUBLIC_ADMIN_UIDS, NEXT_PUBLIC_STAFF_UIDS
ADMIN_UIDS=
STAFF_UIDS=
NEXT_PUBLIC_ADMIN_UIDS=
NEXT_PUBLIC_STAFF_UIDS=

# Second-step portal passwords (server-only; never use NEXT_PUBLIC_*)
# Users sign in with Google first, then enter the role password.
ADMIN_ACCESS_PASSWORD=
STAFF_ACCESS_PASSWORD=
PORTAL_SECRET=

